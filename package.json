{
  "name": "@egghead/standalone",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev --filter=@egghead/web",
    "build": "turbo build",
    "typecheck": "turbo typecheck && tsc --noEmit -p tsconfig.scripts.json",
    "typecheck:tsgo": "turbo typecheck:tsgo && tsgo --noEmit -p tsconfig.scripts.json",
    "lint": "oxlint --type-aware --deny-warnings .",
    "lint:fix": "oxlint --type-aware --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "phase0:imports": "tsx --tsconfig apps/web/tsconfig.json scripts/phase0-imports.ts",
    "routing:v2-contract": "tsx --tsconfig apps/web/tsconfig.json scripts/routing-v2-contract.ts",
    "beta:runtime-guard": "tsx --tsconfig apps/web/tsconfig.json scripts/beta-runtime-guard.ts",
    "check": "pnpm typecheck && pnpm typecheck:tsgo && pnpm lint && pnpm format:check && pnpm phase0:imports && pnpm routing:v2-contract && pnpm beta:runtime-guard",
    "hooks:install": "lefthook install",
    "hooks:pre-commit": "lefthook run pre-commit --all-files"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "1.0.4",
    "@types/node": "^20.19.25",
    "@typescript/native-preview": "7.0.0-dev.20260607.1",
    "lefthook": "2.1.9",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.3.0"
}
